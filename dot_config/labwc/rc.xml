<labwc_config>

    <theme>
        <name>Void-JDK</name>
        <cornerRadius>0</cornerRadius>
        <font name="DungGeunMo" size="12" />
        <titlebar>
            <layout>icon:iconify,max,close</layout>
            <showTitle>yes</showTitle>
        </titlebar>
    </theme>
    
    <keyboard>
        <repeatRate>25</repeatRate>
        <repeatDelay>500</repeatDelay>
        
        <keybind key="A-Tab">
            <action name="NextWindow" />
        </keybind>

        <keybind key="A-F4">
            <action name="Close" />
        </keybind>

        <keybind key="Print">
            <action name="Execute">
                <command>sh -c 'grim $(xdg-user-dir PICTURES)/$(date +'%s-grim.png')'</command>
            </action>
        </keybind>

        <keybind key="A-Print">
            <action name="Execute">
                <command>sh -c 'grim -g "$(slurp)" - | swappy -f -'</command>
            </action>
        </keybind>

        <keybind key="W-d">
            <action name="ToggleDecorations" />
        </keybind>

        <keybind key="W-f">
            <action name="Execute" command="gtk-launch firefox" />
        </keybind>

        <keybind key="W-t">
            <action name="Execute" command="thunar" />
        </keybind>
        
        <keybind key="W-Return">
            <action name="Execute" command="lab-sensible-terminal" />
        </keybind>

        <keybind key="W-Tab" onRelease="yes">
            <action name="GoToDesktop" to="right" wrap="yes" toggle="yes" />
        </keybind>
        
        <keybind key="W-Left">
            <action name="SnapToEdge" direction="left" combine="yes" />
        </keybind>

        <keybind key="W-Right">
            <action name="SnapToEdge" direction="right" combine="yes" />
        </keybind>
        
        <keybind key="W-Up">
            <action name="SnapToEdge" direction="up" combine="yes" />
        </keybind>
        
        <keybind key="W-Down">
            <action name="SnapToEdge" direction="down" combine="yes" />
        </keybind>
    
        <keybind key="XF86MonBrightnessUp">
            <action name="Execute" command="brightnessctl -q set +5%" />
        </keybind>

        <keybind key="XF86MonBrightnessDown">
            <action name="Execute" command="brightnessctl -q set 5%-" />
        </keybind>
    </keyboard>
    
    <desktops>
      <popupTime>750</popupTime>
      <initial>1</initial>
      <names>
        <name>1</name>
        <name>2</name>
        <name>3</name>
        <name>4</name>
      </names>
    </desktops>

</labwc_config>
